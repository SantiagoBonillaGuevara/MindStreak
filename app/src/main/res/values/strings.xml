    <string name="privacy_back_desc">Back</string>
    <string name="privacy_last_updated">Last updated: April 2024</string>
    <string name="privacy_section_1_title">1. Data Collection</string>
    <string name="privacy_section_1_desc">We collect data about your habits, streaks, and achievements to provide you with personalized statistics and rewards. Your email is used only for account authentication.</string>
    <string name="privacy_section_2_title">2. Data Usage</string>
    <string name="privacy_section_2_desc">Your progress is shared with friends only if you choose to participate in social features. We never sell your personal data to third parties.</string>
    <string name="privacy_section_3_title">3. Your Rights</string>
    <string name="privacy_section_3_desc">You can delete your account and all associated data at any time from the account settings. We respect your right to be forgotten.</string>
    <string name="privacy_footer">By using MindStreak, you agree to our Terms of Service.</string>

